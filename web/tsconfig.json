{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["esnext"],
    "strict": true,
    "types": [
      "@cloudflare/workers-types"
    ],
    "paths": {
      "@glua/shared": ["./shared"],
      "@glua/shared/*": ["./shared/*"]
    }
  },
  "include": ["src/**/*.ts", "shared/**/*.ts"]
}
